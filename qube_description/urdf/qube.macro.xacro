<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="qube" params="prefix">

    <xacro:property name="base_size" value="0.102"/>
    <xacro:property name="disk_radius" value="0.025"/>
    <xacro:property name="disk_height" value="0.010"/>
    <xacro:property name="indicator_length" value="0.025"/>
    <xacro:property name="indicator_width" value="0.002"/>
    <xacro:property name="indicator_height" value="0.002"/>

    <link name="${prefix}base_link"/>

    <link name="${prefix}stator_link">
      <visual>
        <origin xyz="0 0 ${base_size/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_size} ${base_size} ${base_size}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}rotor_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${disk_radius}" length="${disk_height}"/>
        </geometry>
        <material name="red">
          <color rgba="1.0 0.0 0.0 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}angle_link">
      <visual>
        <origin xyz="${indicator_length/2} 0 ${indicator_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${indicator_length} ${indicator_width} ${indicator_height}"/>
        </geometry>
        <material name="white">
          <color rgba="1.0 1.0 1.0 1.0"/>
        </material>
      </visual>
    </link>

    <joint name="${prefix}stator_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}stator_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}motor_joint" type="continuous">
      <parent link="${prefix}stator_link"/>
      <child link="${prefix}rotor_link"/>
      <origin xyz="0 0 ${base_size}" rpy="0 0 0"/>
      <axis xyz="0 0 -1"/>
    </joint>

    <joint name="${prefix}indicator_joint" type="fixed">
      <parent link="${prefix}rotor_link"/>
      <child link="${prefix}angle_link"/>
      <origin xyz="0 0 ${disk_height/2}" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>